# Per-host identity (matches Tailscale hostname / Prometheus instance label).
# Examples: streamrtn1, streamrtn2
HOST_ID=streamrtn1

# Optional Cloudflare Tunnel (just up-tunnel). Not required for remote_write.
# Tunnel name convention: monitoring-slice-<HOST_ID>
# TUNNEL_TOKEN=

# Image pins (override only when upgrading intentionally)
CLOUDFLARED_VERSION=2026.7.1
PROMETHEUS_VERSION=v3.13.1
NODE_EXPORTER_VERSION=v1.12.0
BLACKBOX_EXPORTER_VERSION=v0.28.0
JSON_EXPORTER_VERSION=v0.7.0
SPEEDTEST_TRACKER_VERSION=1.14.5
TZ=Europe/Dublin

# Speedtest Tracker — generate APP_KEY on Cherry or any host:
#   docker run --rm --entrypoint php lscr.io/linuxserver/speedtest-tracker:1.14.5 artisan key:generate --show
SPEEDTEST_PORT=8765
SPEEDTEST_APP_KEY=
SPEEDTEST_SCHEDULE=0 */6 * * *
# SPEEDTEST_SERVERS=

# -----------------------------------------------------------------------------
# Prometheus Agent: local scrapes → Cherry over Tailscale remote_write
# Cherry must run Prometheus with --web.enable-remote-write-receiver.
REMOTE_WRITE_URL=

# Blackmagic Web Presenters for this stream package.
# Use base URLs with no trailing slash.
WP_PRIMARY_URL=http://192.168.x.x
WP_SECONDARY_URL=http://192.168.x.y

# Local debug ports remain published for direct checks, but Cherry receives
# slice metrics from this Agent rather than scraping these ports directly.
# Restrict host ports with Tailscale ACLs / host firewall.
# Docs: https://picomms.github.io/monitoring-nia-pi/developer/slice/
# -----------------------------------------------------------------------------
